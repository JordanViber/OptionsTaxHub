{
  "name": "options-tax-hub-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "npx kill-port 8001",
    "start": "node venv-python.js -m uvicorn main:app --host 0.0.0.0 --port 8001",
    "dev": "node venv-python.js -m uvicorn main:app --host 0.0.0.0 --port 8001 --reload",
    "test": "node venv-python.js -m pytest",
    "test:coverage": "node venv-python.js -m pytest --cov=. --cov-report=term-missing",
    "test:watch": "node venv-python.js -m pytest --watch"
  }
}
