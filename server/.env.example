# Database
DATABASE_URL=postgresql://user:password@localhost:5432/optionstaxhub

# API Keys
API_KEY_SECRET=your_secret_key_here

# CORS
FRONTEND_URL=http://localhost:3000

# Port (optional, defaults to 8000)
PORT=8000

# Set to "development" to enable auto-reload (local dev only)
ENVIRONMENT=development

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_JWT_SECRET=your_jwt_secret_here

# Push Notifications (Web Push)
# Generate keys with: npm run generate:vapid-keys (in client folder)
# For local development, see .vapid-keys file
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_CLAIM_EMAIL=mailto:your-email@example.com
